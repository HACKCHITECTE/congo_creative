generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. Les Utilisateurs (Admins et Jurys)
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      Role     @default(USER)
  scores    Score[]  // Les notes attribuées par ce jury
  createdAt DateTime @default(now())
}

enum Role {
  USER
  JURY
  ADMIN
}

// Les Talents Créatifs
model Talent {
  id            String   @id @default(cuid())
  fullName      String
  profilePictureUrl String?
  job           String   // Design, Motion, Montage, Marketing
  city          String
  whatsapp      String
  email         String   @unique
  portfolioUrl  String   // Lien site web ou portfolio principal
  behanceUrl    String?  // NOUVEAU : Lien Behance
  linkedinUrl   String?  // NOUVEAU : Lien LinkedIn
  bio           String?  @db.Text
  availability  String   // Freelance, CDI, Projet
  globalScore   Float    @default(0)
  projects      Project[]
  createdAt     DateTime @default(now())
}

// 3. Les Projets soumis
model Project {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  mediaUrl    String?  // Lien image ou vidéo (YouTube/Vimeo)
  processUrl  String?
  talentId    String
  talent      Talent   @relation(fields: [talentId], references: [id])
  scores      Score[]
}


// 4. Le Système de Scoring (Weights inclus pour la logique future)
model Score {
  id            String   @id @default(cuid())
  originality   Float
  aesthetic     Float
  finish        Float
  toolMastery   Float
  complexity    Float
  organization  Float
  potential     Float
  presentation  Float
  engagement    Float
  publicVote    Float
  finalScore    Float
  
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id])
  juryId        String
  user          User     @relation(fields: [juryId], references: [id])
  createdAt     DateTime @default(now())
}